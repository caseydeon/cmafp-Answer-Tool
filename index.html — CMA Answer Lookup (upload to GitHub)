const sortedBooks=Object.keys(BOOKS).sort();
const bookSelect=document.getElementById('bookSelect');
const pageInput=document.getElementById('pageInput');
const resultsDiv=document.getElementById('results');
const infoBar=document.getElementById('infoBar');
const bookCount=document.getElementById('bookCount');

sortedBooks.forEach(name=>{const o=document.createElement('option');o.value=name;o.textContent=name;bookSelect.appendChild(o);});
bookCount.textContent=sortedBooks.length+' books loaded';

function lookup(){
  const bn=bookSelect.value,pn=parseInt(pageInput.value);
  if(!bn){showMsg('Please select a book first.');return;}
  if(!pn||pn<1){showMsg('Please enter a valid page number.');return;}
  const book=BOOKS[bn];
  if(book.needsManualEntry){showMsg('⚠️ This book requires manual data entry — OCR extraction failed. Please refer to the physical book.');return;}
  const ans=book.pages[pn];
  if(!ans){
    infoBar.style.display='none';
    const avail=Object.keys(book.pages).sort((a,b)=>+a-+b).join(', ');
    resultsDiv.innerHTML=`<div class="result-card"><div class="empty-state"><div class="icon">⚠️</div><p>No answers for <strong>${bn}</strong> — Page <strong>${pn}</strong>.</p><p style="margin-top:8px;font-size:13px;color:#7a82a0">Available pages: ${avail}</p></div></div>`;
    return;
  }
  if(typeof ans==='object'&&!Array.isArray(ans)&&(ans.mul||ans.div)){
    infoBar.style.display='flex';
    if(!ans.mul&&ans.div){
      infoBar.innerHTML=`ℹ️ <strong>÷ Division (decimal)</strong> — ${bn} Page ${pn}`;
      resultsDiv.innerHTML=`<div class="result-card"><div class="result-header"><h2>${bn} — Page ${pn}</h2><span class="badge" style="color:#f9a825;background:rgba(249,168,37,0.15);border-color:rgba(249,168,37,0.3)">÷ Division</span></div><div class="answers-grid">${ans.div.map((a,i)=>`<div class="answer-cell"><div class="answer-num">Q${i+1} ÷</div><div class="answer-val" style="color:#f9a825">${a??'—'}</div></div>`).join('')}</div></div>`;
      return;
    }
    infoBar.innerHTML=`ℹ️ <strong>× Multiplication + ÷ Division</strong> — ${bn} Page ${pn}`;
    resultsDiv.innerHTML=`<div class="result-card"><div class="result-header"><h2>${bn} — Page ${pn} (×)</h2><span class="badge">× Multiply</span></div><div class="answers-grid">${ans.mul.map((a,i)=>`<div class="answer-cell"><div class="answer-num">Q${i+1} ×</div><div class="answer-val">${a!=null?a.toLocaleString():'—'}</div></div>`).join('')}</div></div><div style="height:12px"></div><div class="result-card"><div class="result-header"><h2>${bn} — Page ${pn} (÷)</h2><span class="badge" style="color:#f9a825;background:rgba(249,168,37,0.15);border-color:rgba(249,168,37,0.3)">÷ Divide</span></div><div class="answers-grid">${ans.div.map((a,i)=>`<div class="answer-cell"><div class="answer-num">Q${i+1} ÷</div><div class="answer-val" style="color:#f9a825">${a!=null?a.toLocaleString():'—'}</div></div>`).join('')}</div></div>`;
    return;
  }
  infoBar.style.display='flex';
  infoBar.innerHTML=`ℹ️ <strong>${ans.length} answers</strong> — ${bn} · Page ${pn}`;
  resultsDiv.innerHTML=`<div class="result-card"><div class="result-header"><h2>${bn} — Page ${pn}</h2><span class="badge">${ans.length} answers</span></div><div class="answers-grid">${ans.map((a,i)=>`<div class="answer-cell"><div class="answer-num">Q${i+1}</div><div class="answer-val">${a??'—'}</div></div>`).join('')}</div></div>`;
}
function showMsg(m){infoBar.style.display='none';resultsDiv.innerHTML=`<div class="result-card"><div class="empty-state"><p>${m}</p></div></div>`;}
pageInput.addEventListener('keydown',e=>{if(e.key==='Enter')lookup();});
bookSelect.addEventListener('change',()=>{resultsDiv.innerHTML='';infoBar.style.display='none';});
resultsDiv.innerHTML=`<div class="result-card"><div class="empty-state"><div class="icon">📖</div><p>Select a book and enter a page number to look up the answers.</p></div></div>`;
</script>
